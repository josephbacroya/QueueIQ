@page "/join/{Slug}"
@rendermode InteractiveServer
@using QueueIQ.Shared.DTOs
@using QueueIQ.Shared.Enums
@inject IHttpClientFactory ClientFactory
@inject NavigationManager NavManager
@inject IJSRuntime JS

<PageTitle>Join Queue - QueueIQ</PageTitle>

<div class="container mt-5 px-3 max-w-md mx-auto" style="max-width: 500px;">
    @if (_errorMessage is not null)
    {
        <div class="alert shadow-sm border-0 rounded-3 mb-4" role="alert" style="background-color: var(--surface-3); color: var(--red); border: 1px solid var(--red) !important;">
            @_errorMessage
        </div>
    }
    else if (_business is null)
    {
        <div class="text-center py-5">
            <div class="spinner-border" style="color: var(--blue);" role="status"></div>
            <p class="mt-3 fw-semibold" style="color: var(--text-2);">Loading business...</p>
        </div>
    }
    else
    {
        <div class="glass-card p-4">
            <div class="text-center mb-5 d-flex flex-column align-items-center">
                <svg viewBox="0 0 52 52" style="width:48px; height:48px; margin-bottom:1rem;">
                    <defs>
                        <linearGradient id="qgrad3" x1="0" y1="0" x2="1" y2="1">
                            <stop offset="0%" stop-color="#4f7df0"/>
                            <stop offset="100%" stop-color="#9b5cf0"/>
                        </linearGradient>
                    </defs>
                    <circle cx="26" cy="26" r="22" fill="none" stroke="url(#qgrad3)" stroke-width="7"/>
                    <line x1="35" y1="35" x2="44" y2="44" stroke="url(#qgrad3)" stroke-width="7" stroke-linecap="round"/>
                </svg>
                <h2 class="fw-bold mb-2 font-space text-gradient">@_business.Name</h2>
                <p class="mb-0" style="color: var(--text-2);">Select a service to join the queue</p>
            </div>

            <div class="mb-5">
                @foreach (var service in _business.ServiceTypes)
                {
                    <button type="button" class="ios-btn-select @(_selectedServiceId == service.Id ? "active" : "")" @onclick="() => SelectService(service.Id)">
                        <div>
                            <div class="fw-semibold fs-5 mb-1 font-space" style="color: var(--text-0);">@service.Name</div>
                            <div class="small" style="color: var(--text-2);">Avg. @service.AvgDurationMinutes mins</div>
                        </div>
                        @if (_selectedServiceId == service.Id)
                        {
                            <svg viewBox="0 0 24 24" fill="none" stroke="var(--blue)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="width:24px;height:24px;"><polyline points="20 6 9 17 4 12"/></svg>
                        }
                        else
                        {
                            <svg viewBox="0 0 24 24" fill="none" stroke="var(--text-3)" stroke-width="2" style="width:24px;height:24px;"><circle cx="12" cy="12" r="10"/></svg>
                        }
                    </button>
                }
            </div>

            <button class="btn-apple-primary font-space w-100" style="padding: 1rem;" disabled="@(_selectedServiceId == Guid.Empty || _isSubmitting)" @onclick="JoinQueueAsync">
                @if (_isSubmitting)
                {
                    <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                    <span>Joining...</span>
                }
                else
                {
                    <span class="fs-5">Join Queue</span>
                }
            </button>
        </div>
    }
</div>

@code {
    [Parameter]
    public string Slug { get; set; } = string.Empty;

    private BusinessDto? _business;
    private Guid _selectedServiceId;
    private string? _errorMessage;
    private bool _isSubmitting;
    private HttpClient _api = default!;
    private string? _customerToken;

    protected override void OnInitialized()
    {
        _api = ClientFactory.CreateClient("ApiClient");
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Load business data AFTER the interactive circuit is connected,
            // so prerendering isn't blocked and @onclick handlers work immediately.
            await LoadBusinessAsync();
            StateHasChanged();

            try
            {
                _customerToken = await JS.InvokeAsync<string>("localStorage.getItem", "customerToken");
                if (!string.IsNullOrEmpty(_customerToken))
                {
                    var response = await _api.GetAsync($"/api/businesses/{Slug}/queue/active-ticket?token={_customerToken}");
                    if (response.IsSuccessStatusCode)
                    {
                        var activeTicket = await response.Content.ReadFromJsonAsync<TicketDto>();
                        if (activeTicket is not null)
                        {
                            NavManager.NavigateTo($"/queue/{Slug}/{activeTicket.Id}");
                            return;
                        }
                    }
                }
            }
            catch
            {
                // Ignore JS or network errors
            }
        }
    }

    private async Task LoadBusinessAsync()
    {
        try
        {
            var response = await _api.GetAsync($"/api/businesses/{Slug}");
            if (response.IsSuccessStatusCode)
            {
                _business = await response.Content.ReadFromJsonAsync<BusinessDto>();
            }
            else
            {
                _errorMessage = "Business not found.";
            }
        }
        catch (Exception ex)
        {
            _errorMessage = "Failed to load business details.";
        }
    }

    private void SelectService(Guid serviceId)
    {
        _selectedServiceId = serviceId;
    }

    private async Task JoinQueueAsync()
    {
        if (_selectedServiceId == Guid.Empty) return;

        _isSubmitting = true;
        _errorMessage = null;
        StateHasChanged();

        if (string.IsNullOrEmpty(_customerToken))
        {
            _customerToken = Guid.NewGuid().ToString("N")[..12];
            try { await JS.InvokeVoidAsync("localStorage.setItem", "customerToken", _customerToken); } catch { }
        }

        try
        {
            var response = await _api.PostAsJsonAsync($"/api/businesses/{Slug}/queue", new CreateTicketDto(_selectedServiceId, _customerToken));
            
            if (response.IsSuccessStatusCode)
            {
                var ticket = await response.Content.ReadFromJsonAsync<TicketDto>();
                if (ticket is not null)
                {
                    NavManager.NavigateTo($"/queue/{Slug}/{ticket.Id}");
                }
            }
            else
            {
                _errorMessage = "Failed to join queue. Please try again.";
            }
        }
        catch (Exception ex)
        {
            _errorMessage = "Network error. Please try again.";
        }
        finally
        {
            _isSubmitting = false;
        }
    }
}
