@page "/queue/{Slug}/{TicketId:guid}"
@rendermode InteractiveServer
@using QueueIQ.Shared.DTOs
@using QueueIQ.Shared.Enums
@using QueueIQ.Web.Services
@implements IAsyncDisposable
@inject QueueHubService HubService
@inject IHttpClientFactory ClientFactory

<PageTitle>Your Queue Position</PageTitle>

<div class="container mt-5 px-3 max-w-md mx-auto" style="max-width: 500px;">
    @if (_isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border" style="color: var(--blue);" role="status"></div>
            <p class="mt-3 fw-semibold" style="color: var(--text-2);">Loading your status...</p>
        </div>
    }
    else if (_errorMessage is not null)
    {
        <div class="alert shadow-sm border-0 rounded-4 p-4" role="alert" style="background-color: var(--surface-3); color: var(--red); border: 1px solid var(--red) !important;">
            @_errorMessage
        </div>
    }
    else if (_position is not null)
    {
        <div class="glass-card text-center p-5">
            <span class="badge-apple mb-4 d-inline-block font-space">@_position.ServiceTypeName</span>
            
            @if (_position.Status == TicketStatus.Waiting)
            {
                <div class="queue-item-enter">
                    <h4 class="mb-2 fw-normal font-space" style="color: var(--text-2);">People ahead of you</h4>
                    <div class="text-massive mb-4">@_position.Position</div>
                    
                    @if (_position.EstimatedWaitMinutes.HasValue)
                    {
                        <div class="mt-4 p-3 rounded-4 bg-light">
                            <div class="small fw-semibold text-uppercase tracking-wider mb-1" style="color: var(--text-3); font-size: 0.75rem; letter-spacing: 0.05em;">Estimated Wait</div>
                            <div class="fs-4 fw-bold font-space" style="color: var(--text-0);">
                                @_position.EstimatedWaitMinutes.Value.ToString("F0") <span class="fs-6 fw-normal" style="color: var(--text-2);">mins</span>
                            </div>
                        </div>
                    }
                    
                    <p class="small mt-4 mb-0" style="color: var(--text-2);">
                        This screen updates automatically.<br>We'll notify you when it's your turn.
                    </p>
                </div>
            }
            else if (_position.Status == TicketStatus.Called)
            {
                <div class="queue-item-enter py-4">
                    <div class="mb-4">
                        <div class="spinner-grow" style="width: 3rem; height: 3rem; color: var(--green);" role="status">
                            <span class="visually-hidden">Loading...</span>
                        </div>
                    </div>
                    <h1 class="display-5 fw-bold mb-3 font-space" style="color: var(--green);">You're Next!</h1>
                    <p class="fs-5 mb-0" style="color: var(--text-1);">Please head to the counter now.</p>
                </div>
            }
            else if (_position.Status == TicketStatus.InService)
            {
                <div class="queue-item-enter py-4">
                    <div class="mb-3" style="color: var(--blue);">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:64px;height:64px;">
                            <circle cx="6" cy="6" r="3"/><circle cx="6" cy="18" r="3"/><line x1="20" y1="4" x2="8.12" y2="15.88"/><line x1="14.47" y1="14.48" x2="20" y2="20"/><line x1="8.12" y1="8.12" x2="12" y2="12"/>
                        </svg>
                    </div>
                    <h3 class="fw-bold font-space text-gradient">In Service</h3>
                    <p class="mb-0" style="color: var(--text-2);">You are currently being served.</p>
                </div>
            }
            else if (_position.Status == TicketStatus.Done)
            {
                <div class="queue-item-enter py-4">
                    <div class="mb-3" style="color: var(--green);">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:64px;height:64px;">
                            <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/>
                        </svg>
                    </div>
                    <h3 class="fw-bold font-space" style="color: var(--green);">All Done!</h3>
                    <p class="mb-0" style="color: var(--text-2);">Thanks for visiting.</p>
                </div>
            }
        </div>
    }
</div>

@code {
    [Parameter]
    public string Slug { get; set; } = string.Empty;

    [Parameter]
    public Guid TicketId { get; set; }

    private QueuePositionDto? _position;
    private string? _errorMessage;
    private bool _isLoading = true;
    private HttpClient _api = default!;

    protected override async Task OnInitializedAsync()
    {
        _api = ClientFactory.CreateClient("ApiClient");
        HubService.OnQueueUpdated += HandleQueueUpdated;
        
        await LoadPositionAsync();
        await HubService.StartAsync(Slug);
        
        _isLoading = false;
    }

    private async Task LoadPositionAsync()
    {
        try
        {
            var response = await _api.GetAsync($"/api/queue/tickets/{TicketId}/position");
            if (response.IsSuccessStatusCode)
            {
                _position = await response.Content.ReadFromJsonAsync<QueuePositionDto>();
                _errorMessage = null;
            }
            else
            {
                _errorMessage = "Could not find your ticket.";
            }
        }
        catch (Exception ex)
        {
            _errorMessage = "Error connecting to server.";
        }
    }

    private async void HandleQueueUpdated(IEnumerable<TicketDto> queue)
    {
        var myTicket = queue.FirstOrDefault(t => t.Id == TicketId);
        
        if (myTicket is not null)
        {
            _position = new QueuePositionDto(
                myTicket.Id,
                myTicket.Position,
                myTicket.Status,
                myTicket.PredictedWaitMinutes,
                myTicket.ServiceTypeName
            );
            await InvokeAsync(StateHasChanged);
        }
        else
        {
            await InvokeAsync(async () => {
                await LoadPositionAsync();
                StateHasChanged();
            });
        }
    }

    public async ValueTask DisposeAsync()
    {
        HubService.OnQueueUpdated -= HandleQueueUpdated;
        await HubService.DisposeAsync();
    }
}
