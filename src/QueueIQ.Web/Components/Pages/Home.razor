@page "/"

<PageTitle>QueueIQ Home</PageTitle>

<div class="container mt-5 text-center">
    <h1 class="display-4">Welcome to QueueIQ</h1>
    <p class="lead mt-3">This is the development home page. Use the links below to test the queue lifecycle.</p>
    
    <div class="mt-5 d-flex justify-content-center gap-4">
        <div class="card p-4 shadow-sm" style="width: 18rem;">
            <h3>Staff View</h3>
            <p class="text-muted">Manage the queue, call next customer.</p>
            <a href="/staff/joes-barbershop" class="btn btn-primary mt-auto">Open Dashboard</a>
        </div>
        
        <div class="card p-4 shadow-sm" style="width: 18rem;">
            <h3>Customer View</h3>
            <p class="text-muted">Scan QR code or click link to join.</p>
            <a href="/join/joes-barbershop" class="btn btn-outline-primary mt-auto">Join Queue</a>
        </div>
    </div>
</div>
